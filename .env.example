# PostgreSQL (optional locally — without it, Diia users are kept in memory until server restarts)
# DATABASE_URL=postgresql://user:pass@localhost:5432/prostir
#
# ── Admin leads panel: /admin/leads + Prisma Lead table ──
# Secret for X-Admin-Token (same value in the browser gate)
# ADMIN_LEADS_SECRET=change-me-long-random
# Optional: header pill Maintenance vs Live (default: live)
# ADMIN_PANEL_MODE=maintenance

# App session JWT — optional in development (insecure fallback is used if unset)
# SESSION_JWT_SECRET=change-me-to-a-long-random-string

# Mock Diia: set to false in real production. If unset, defaults to mock mode when NODE_ENV is not production.
# USE_DIIA_MOCK=true

# Secret used to sign/verify mock "Diia" tokens (must match between connect and callback)
DIIA_MOCK_SECRET=dev-diia-mock-change-me

# Optional overrides for mock identity
# DIIA_MOCK_SUB=UA-DIIA-MOCK-0001
# DIIA_MOCK_FULL_NAME=Тестовий Користувач Дія

# Public URL of your app (Diia mock return URL, must match where /auth/diia/callback is reachable)
# Local: http://localhost:8080
# Railway: https://prostir-web-production.up.railway.app
# PUBLIC_APP_URL=http://localhost:8080

# Production: PEM-encoded Diia public key for RS256 verification when USE_DIIA_MOCK=false
# DIIA_JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

NODE_ENV=development
# API server (Railway injects PORT). Default local fallback: 8080. Static frontends on GitHub Pages call the Railway URL from the bundled client.
PORT=8080

# ── Venue registration form: POST /api/venue/register (nodemailer) ──
# Recipient (default if unset: shepytkod@gmail.com)
# VENUE_NOTIFY_TO=shepytkod@gmail.com
# Gmail example: use an App Password, not your normal password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-account@gmail.com
# SMTP_PASS=your-app-password
# Optional From header (default: PROSTIR <SMTP_USER>)
# SMTP_FROM=PROSTIR <your-account@gmail.com>

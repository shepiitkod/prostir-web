{
  "name": "prostir-urban-os",
  "version": "1.0.0",
  "description": "PROSTIR — Urban Operating System for Kyiv",
  "homepage": "https://shepiitkod.github.io/prostir-web/",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && npm run build:client && npm run build:venue && npm run build:business-receipt",
    "build:client": "esbuild client/diia/app.tsx --bundle --minify --outfile=public/diia-auth.bundle.js --format=iife --platform=browser --jsx=automatic",
    "build:venue": "esbuild client/venue/app.tsx --bundle --minify --outfile=public/venue-register.bundle.js --format=iife --platform=browser --jsx=automatic",
    "build:business-receipt": "esbuild client/business/humanReceiptMount.tsx --bundle --minify --outfile=public/business-human-receipt.bundle.js --format=iife --platform=browser --jsx=automatic",
    "build:gh-pages": "npm run build:client && npm run build:venue && npm run build:business-receipt && node scripts/prepare-gh-pages.mjs",
    "start": "node server.js",
    "dev": "tsx watch src/server.ts",
    "dev:once": "tsx src/server.ts",
    "verify": "tsc --noEmit && node --check server.js && for f in public/*.js; do node --check \"$f\"; done"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.2",
    "motion": "^12.38.0",
    "nodemailer": "^8.0.4",
    "pg": "^8.13.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
